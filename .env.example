################################################################################
# 🚀 NEXO DIGITAL STORE - Environment Configuration Example
# 
# INSTRUCTIONS:
# 1. Copy this file to `.env`: cp .env.example .env
# 2. Generate app key: php artisan key:generate
# 3. Fill in all marked with [REQUIRED] and [PRODUCTION]
# 4. NEVER commit .env to version control
# 5. For production, ensure all credentials are stored securely
################################################################################

# ── Application Settings ──────────────────────────────────────────────────────
APP_NAME="Nexo Digital Store"
APP_ENV=local                              # [PRODUCTION] Change to: production
APP_KEY=                                   # Leave empty, run: php artisan key:generate
APP_DEBUG=true                             # [PRODUCTION] Change to: false
APP_URL=http://localhost:8000              # [REQUIRED] Set to your domain

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12                           # [SECURITY] Increase for production (14-15)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                            # [PRODUCTION] Change to: warning or error

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                          # [PRODUCTION] Use RDS endpoint or actual DB host
DB_PORT=3306
DB_DATABASE=nexo_digital_store
DB_USERNAME=nexo                           # [REQUIRED] Strong username
DB_PASSWORD=secret                         # [REQUIRED] Strong password (min 16 chars)

# ── Session Configuration ─────────────────────────────────────────────────────
SESSION_DRIVER=redis                       # Cache driver (redis recommended)
SESSION_LIFETIME=120                       # Minutes
SESSION_ENCRYPT=false                      # [PRODUCTION] Change to: true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting & Queueing ──────────────────────────────────────────────────
BROADCAST_CONNECTION=log                   # [PRODUCTION] Change to: redis
FILESYSTEM_DISK=local                      # [PRODUCTION] Change to: s3 or cloudinary
QUEUE_CONNECTION=redis

# ── Cache & Redis ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=nexo_

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1                       # [PRODUCTION] Use Redis host/endpoint
REDIS_PASSWORD=null                        # [PRODUCTION] Set strong password if required
REDIS_PORT=6379

# ── Mail Configuration ────────────────────────────────────────────────────────
MAIL_MAILER=log                            # [PRODUCTION] Change to: smtp, sendmail, mailgun
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@nexodigitalstore.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: Mailgun configuration (uncomment if using Mailgun)
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=

# Optional: SendGrid configuration (uncomment if using SendGrid)
# SENDGRID_API_KEY=

# ── AWS S3 (Optional File Storage) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Cloudinary (Image Storage) ────────────────────────────────────────────────
# [REQUIRED] Get credentials from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=nexo-digital-store

# ── PayPal Integration ────────────────────────────────────────────────────────
# [REQUIRED FOR PAYMENTS] Get from: https://developer.paypal.com/dashboard/
PAYPAL_MODE=sandbox                        # [PRODUCTION] Change to: live
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_LIVE_CLIENT_ID=                     # [PRODUCTION] Only if mode=live
PAYPAL_LIVE_CLIENT_SECRET=                 # [PRODUCTION] Only if mode=live
PAYPAL_WEBHOOK_ID=

# ── MercadoPago Integration (Perú) ────────────────────────────────────────────
# [REQUIRED FOR PAYMENTS] Get from: https://www.mercadopago.com.pe/developers
MERCADOPAGO_MODE=sandbox                   # [PRODUCTION] Change to: production
MERCADOPAGO_SANDBOX_PUBLIC_KEY=
MERCADOPAGO_SANDBOX_ACCESS_TOKEN=
MERCADOPAGO_LIVE_PUBLIC_KEY=                # [PRODUCTION] Only if mode=production
MERCADOPAGO_LIVE_ACCESS_TOKEN=              # [PRODUCTION] Only if mode=production
MERCADOPAGO_WEBHOOK_SECRET=

# ── Google OAuth (Social Login) ───────────────────────────────────────────────
# [OPTIONAL] Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Steam OAuth (Social Login) ───────────────────────────────────────────────
# [OPTIONAL] Get from: https://steamcommunity.com/dev/apikey
STEAM_CLIENT_ID=
STEAM_CLIENT_SECRET=
STEAM_REDIRECT_URI="${APP_URL}/auth/steam/callback"

# ── NexoTokens (NT) - Custom Currency ─────────────────────────────────────────
NEXO_TOKEN_NAME="NexoToken"
NEXO_TOKEN_SYMBOL="NT"
NEXO_TOKEN_RATE_USD=0.10                   # 1 NT = $0.10 USD
NEXO_CASHBACK_RATE=2                       # % of cashback in NT per purchase
NEXO_INVENTORY_RESERVATION_MINUTES=15      # Time to reserve keys before payment

# ── Telegram Bot (Optional) ───────────────────────────────────────────────────
# [OPTIONAL] Create bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL="${APP_URL}/webhook/telegram"

# ── Additional Security Settings ──────────────────────────────────────────────
# [PRODUCTION] Sentry for error tracking
# SENTRY_LARAVEL_DSN=

# [PRODUCTION] Set to your proxy IPs (comma-separated)
# TRUSTED_PROXIES=

# [PRODUCTION] CORS allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=

VITE_APP_NAME="${APP_NAME}"
